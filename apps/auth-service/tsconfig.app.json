{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "out-tsc/auth-service",
    "rootDir": "../../",
    "types": ["node"],
    "moduleResolution": "nodenext", // <-- fix for customConditions & NodeNext modules
    "tsBuildInfoFile": "out-tsc/auth-service/tsconfig.app.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "../../packages/**/*.ts" // <-- include all packages so TS sees them
  ],
  "exclude": [
    "dist",
    "out-tsc",
    "**/*.spec.ts",
    "**/*.test.ts",
    "jest.config.ts",
    "jest.config.cts"
  ]
}
