    <table width="600" style="background:#ffffff; border-radius:8px; overflow:hidden;">
      
      <!-- Header -->
      <tr>
        <td style="background:#4f46e5; color:#ffffff; padding:20px; text-align:center;">
          <h2>Order Confirmed 🎉</h2>
        </td>
      </tr>

      <!-- Content -->
      <tr>
        <td style="padding:24px; color:#333;">

          <p>Hi <strong><%= name %></strong>,</p>
          <p>Thanks for your order!</p>

          <!-- Items -->
          <table width="100%" cellpadding="8" cellspacing="0">
            <tr style="background:#f0f0f0;">
              <th align="left">Product</th>
              <th align="center">Qty</th>
              <th align="right">Price</th>
            </tr>

            <% cart.forEach(item => { %>
              <tr>
                <td><%= item.name %></td>
                <td align="center"><%= item.quantity %></td>
                <td align="right">₹<%= item.price * item.quantity %></td>
              </tr>
            <% }) %>
          </table>

          <!-- Total -->
          <h3 style="margin-top:20px;">Total: ₹<%= totalAmount %></h3>

          <!-- Button -->
          <div style="text-align:center; margin-top:20px;">
            <a href="<%= trackingUrl %>" 
               style="background:#4f46e5; color:#fff; padding:12px 20px; text-decoration:none; border-radius:5px;">
              Track Order
            </a>
          </div>

        </td>
      </tr>

      <!-- Footer -->
      <tr>
        <td style="padding:16px; text-align:center; font-size:12px; color:#777; background:#f9fafb;">
          This is an automated email. Please do not reply.
        </td>
      </tr>

    </table>

  </td>
</tr>
